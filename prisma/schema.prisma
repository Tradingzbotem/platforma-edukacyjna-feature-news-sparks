// prisma/schema.prisma
// Minimal Prisma schema for Redakcja (editorial articles).
// Note: Project primarily uses @vercel/postgres directly; Prisma is added only for this feature.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Article {
  id             String        @id @default(cuid())
  slug           String        @unique
  title          String
  content        String
  readingTime    Int?
  tags           String[]      @default([])
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([createdAt])
}

model MediaAsset {
  id          String   @id @default(cuid())
  url         String   @unique
  pathname    String?
  contentType String?
  size        Int?
  alt         String?
  notes       String?
  isArchived  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([createdAt])
  @@index([isArchived, createdAt])
}

model MacroCalendarEvent {
  id          String   @id @default(cuid())
  date        String   // YYYY-MM-DD
  time        String?  // HH:mm
  currency    String?  // Wal. (currency code)
  event       String   // Wydarzenie (event name)
  weight      String?  // Waga (importance/weight)
  current     String?  // Obecny (current value)
  forecast    String?  // Prognoza (forecast value)
  previous    String?  // Poprzedni (previous value)
  region      String?  // Inferred from currency or event
  importance  String?  // low | medium | high (inferred from weight or event type)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([date])
  @@index([date, importance])
  @@index([createdAt])
}

// Wewnętrzny Founders Pass (bez on-chain). ownerUserId = users.id z tabeli zarządzanej przez @/lib/db.
enum FoundersTokenStatus {
  active
  pending
  transferred
  inactive
  revoked
}

/// Wewnętrzny rekord członkostwa Founders (bez on-chain). Jeden `code` = jeden „slot” NFT w użyciu biznesowym.
model FoundersToken {
  id             String              @id @default(cuid())
  code           String              @unique
  title          String
  description    String              @default("")
  imageUrl       String?             @map("image_url")
  benefitsJson   Json?               @map("benefits_json")
  status         FoundersTokenStatus @default(active)
  transferable   Boolean             @default(true)
  ownerUserId    String?             @map("owner_user_id")

  /// Kto nadał dostęp (users.id z @/lib/db), ustawiane przy przypisaniu z panelu admina.
  grantedByAdminId String? @map("granted_by_admin_id")
  grantedAt        DateTime? @map("granted_at")
  adminNotes       String? @map("admin_notes")
  /// Etykieta NFT w sensie biznesowym (np. „Founders”), bez portfela.
  nftLabel              String   @default("Founders") @map("nft_label")
  /// Gdy true — blokuje transfer użytkownika (obok transferable).
  transferLocked        Boolean  @default(false) @map("transfer_locked")
  /// Wyjątek: dostęp aplikacyjny bez „NFT” (trial / promocja / decyzja admina). Dla statusu pending pozwala na dostęp.
  allowAccessWithoutNft Boolean  @default(false) @map("allow_access_without_nft")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  transfers FoundersTokenTransfer[]

  @@index([ownerUserId])
  @@map("FoundersToken")
}

model FoundersTokenTransfer {
  id         String        @id @default(cuid())
  tokenId    String        @map("token_id")
  token      FoundersToken @relation(fields: [tokenId], references: [id], onDelete: Cascade)
  fromUserId String?       @map("from_user_id")
  toUserId   String?       @map("to_user_id")
  note       String?
  createdAt  DateTime      @default(now()) @map("created_at")

  @@index([tokenId])
  @@map("FoundersTokenTransfer")
}

/// Brief decyzyjny (dzienny) — MVP: jeden rekord roboczy o stałym `slug` (`daily`), publikacja `isPublished`.
model DecisionBrief {
  id                  String   @id @default(cuid())
  slug                String   @unique
  title               String
  summary             String   @default("")
  narrativeAxis       String   @default("") @map("narrative_axis")
  context             String   @default("")
  onRadar             String   @default("") @map("on_radar")
  priorityOfDay       String   @default("") @map("priority_of_day")
  baseScenario        String   @default("") @map("base_scenario")
  alternativeScenario String   @default("") @map("alternative_scenario")
  invalidation        String   @default("")
  isPublished         Boolean  @default(false) @map("is_published")
  publishedAt         DateTime? @map("published_at")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  assets DecisionBriefAsset[]

  @@index([isPublished, publishedAt])
  @@map("decision_briefs")
}

model DecisionBriefAsset {
  id            String        @id @default(cuid())
  briefId       String        @map("brief_id")
  brief         DecisionBrief @relation(fields: [briefId], references: [id], onDelete: Cascade)
  asset         String
  baseDirection String        @default("") @map("base_direction")
  supports      String        @default("")
  weakens       String        @default("")
  sensitivity   String        @default("średnia")
  sortOrder     Int           @default(0) @map("sort_order")

  @@index([briefId, sortOrder])
  @@map("decision_brief_assets")
}

// ─── FXEDULAB Certification (EDU) — moduł certyfikatów (fundament, krok 1) ───

enum CertificationTrack {
  FOREX_FUNDAMENTALS
  TECHNICAL_ANALYSIS
  RISK_MANAGEMENT
}

enum CertificationRecordStatus {
  DRAFT
  ISSUED
  REVOKED
}

model CertificationRecord {
  id                   String                    @id @default(cuid())
  certificateId        String                    @unique @map("certificate_id")
  verificationToken    String                    @unique @map("verification_token")
  fullName             String                    @map("full_name")
  track                CertificationTrack
  scorePercent         Int                       @map("score_percent")
  level                String
  issuedAt             DateTime?                 @map("issued_at")
  status               CertificationRecordStatus @default(DRAFT)
  skillBreakdownJson   Json?                     @map("skill_breakdown_json")
  pdfUrl               String?                   @map("pdf_url")
  userId               String?                   @map("user_id")
  createdByAdminUserId String?                   @map("created_by_admin_user_id")
  notes                String?
  createdAt            DateTime                  @default(now()) @map("created_at")
  updatedAt            DateTime                  @updatedAt @map("updated_at")

  @@index([status, issuedAt])
  @@index([createdAt])
  @@map("certification_records")
}

// ─── FXEDULAB Certification Exam (v1 foundation) ───

enum CertificationExamAttemptStatus {
  NOT_STARTED
  IN_PROGRESS
  SUBMITTED
  PASSED
  FAILED
  EXPIRED
}

/// Podejście do egzaminu certyfikacyjnego (jeden rekord = jedna sesja / próba).
/// Brak tabeli pytań produkcyjnych w v1 — pytania-placeholder i scoring są warstwą aplikacji.
model CertificationExamAttempt {
  id               String                        @id @default(cuid())
  userId           String                        @map("user_id")
  track            CertificationTrack
  status           CertificationExamAttemptStatus @default(NOT_STARTED)
  startedAt        DateTime?                     @map("started_at")
  submittedAt      DateTime?                     @map("submitted_at")
  scorePercent     Int?                          @map("score_percent")
  passed           Boolean?
  answersJson      Json?                         @map("answers_json")
  timeLimitMinutes Int                           @map("time_limit_minutes")
  createdAt        DateTime                      @default(now()) @map("created_at")
  updatedAt        DateTime                      @updatedAt @map("updated_at")

  @@index([userId, status])
  @@index([userId, track])
  @@map("certification_exam_attempts")
}

