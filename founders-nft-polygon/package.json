{
  "name": "founders-nft-polygon",
  "version": "1.0.0",
  "private": true,
  "description": "Minimal ERC-721 FoundersNFT for Polygon (Amoy / mainnet)",
  "scripts": {
    "compile": "hardhat compile",
    "deploy:amoy": "hardhat run scripts/deploy.ts --network polygonAmoy",
    "mint:amoy": "hardhat run scripts/mint.ts --network polygonAmoy",
    "deploy:polygon": "hardhat run scripts/deploy.ts --network polygon",
    "mint:polygon": "hardhat run scripts/mint.ts --network polygon",
    "verify:amoy": "hardhat verify --network polygonAmoy",
    "verify:polygon": "hardhat verify --network polygon"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@openzeppelin/contracts": "^5.2.0",
    "@types/minimatch": "^5.1.2",
    "@types/node": "^22.10.0",
    "dotenv": "^16.4.7",
    "hardhat": "^2.22.17",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2"
  }
}
