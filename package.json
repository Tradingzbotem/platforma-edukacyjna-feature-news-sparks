    "@vercel/blob": "2.0.0",
    "@vercel/postgres": "^0.10.0",
    "bcryptjs": "^3.0.2",
    "fast-xml-parser": "^5.2.5",
    "iron-session": "^8.0.4",
    "lucide-react": "^0.541.0",
    "next": "^15.5.9",
    "next-intl": "^4.9.0",
    "nodemailer": "^6.9.15",
